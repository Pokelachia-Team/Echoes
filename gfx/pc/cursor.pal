; PC_MENU_MODE = red
if !DEF(MONOCHROME)
	RGB 31, 20, 20	; #F8A0A0
	RGB 31, 10, 06	; #F85030
else
	MONOCHROME_RGB_TWO
endc
; PC_SWAP_MODE = blue
if !DEF(MONOCHROME)
	RGB 20, 20, 31	; #A0A0F8
	RGB 06, 10, 31	; #3050F8
else
	MONOCHROME_RGB_TWO
endc
; PC_ITEM_MODE = green
if !DEF(MONOCHROME)
	RGB 20, 28, 20	; #A0E0A0
	RGB 06, 26, 10	; #30D050
else
	MONOCHROME_RGB_TWO
endc
