if !DEF(MONOCHROME)
; red (item and mail)
	RGB 31, 31, 31	; #F8F8F8
	RGB 31, 25, 02	; #F8C810
	RGB 28, 06, 03	; #E03018
	RGB 00, 00, 00	; #000000
; unused
	RGB 31, 31, 31	; #F8F8F8
	RGB 20, 00, 20	; #A000A0
	RGB 10, 00, 10	; #500050
	RGB 00, 00, 00	; #000000
; minis
rept 6
	RGB 31, 31, 31	; #F8F8F8
	RGB 20, 20, 20	; #A0A0A0
	RGB 10, 10, 10	; #505050
	RGB 00, 00, 00	; #000000
endr
else
rept 8
	MONOCHROME_RGB_FOUR
endr
endc
